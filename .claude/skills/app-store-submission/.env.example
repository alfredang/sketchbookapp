# Copy to a gitignored `.env` at the repo root and fill in. Load before running scripts:
#   set -a; source .env; set +a
# The `.p8` private key itself is NEVER committed — keep it at ASC_PRIVATE_KEY_PATH.

# --- App Store Connect API credentials (your automation key) ---
ASC_KEY_ID=<ASC_KEY_ID>                  # 10-char Key ID from Users and Access → Integrations
ASC_ISSUER_ID=<ASC_ISSUER_ID>            # xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_PRIVATE_KEY_PATH=~/.appstoreconnect/private_keys/AuthKey_<ASC_KEY_ID>.p8

# --- App Store Connect web login (for the Playwright UI-only steps: App Privacy,
#     age rating, App Availability). Used to pre-fill the sign-in form only. ---
# ⚠️ Apple enforces 2FA: a human must still approve the 6-digit code on each new
#    browser session — these creds alone cannot give fully-unattended login. Keep the
#    browser session alive across steps to avoid re-auth. NEVER commit (.env is gitignored).
ASC_LOGIN_EMAIL="<APPLE_ID_EMAIL>"
ASC_LOGIN_PASSWORD="<APPLE_ID_PASSWORD>"

# --- App identity ---
ASC_BUNDLE_ID=<BUNDLE_ID>                # reverse-DNS, e.g. com.yourorg.app
ASC_APP_ID=<APP_ID>                      # numeric ASC App ID

# --- Version metadata --- (quote any value with spaces so `source .env` works)
ASC_COPYRIGHT="2026 Tertiary Infotech Academy Pte Ltd"   # format: YYYY Tertiary Infotech Academy Pte Ltd
ASC_PRIVACY_POLICY_URL="<PRIVACY_POLICY_URL>"
ASC_SUPPORT_URL="<SUPPORT_URL>"
ASC_MARKETING_URL="<MARKETING_URL>"

# --- App Review contact ---
ASC_CONTACT_FIRST="<First>"
ASC_CONTACT_LAST="<Last>"
ASC_CONTACT_PHONE="+6596983731"        # always +6596983731
ASC_CONTACT_EMAIL="<CONTACT_EMAIL>"
# Demo/review account must exist on your live backend — verify it logs in before submitting.
ASC_REVIEW_NOTES="Demo account: <REVIEW_ACCOUNT_EMAIL> / <REVIEW_ACCOUNT_PASSWORD>. See screen recording of the in-app Delete Account flow attached in App Review notes."
