# ============================================================================
#  App Store Connect submission .env — Tertiary Infotech Academy standard values
#  Generated by the `create-env` sub-skill of `app-store-submission`.
#
#  ⚠️  SENSITIVE — contains the Apple ID password and ASC key/issuer ids.
#      • The generated `.env` is gitignored in every project — keep it that way.
#      • This sample lives ONLY in the local skill dir; NEVER commit it to GitHub.
#
#  Load before running the submission scripts:  set -a; source .env; set +a
#  Replace every <FILL_…> with the per-project value; the rest are org constants.
# ============================================================================

# --- App Store Connect API credentials (org automation key "CI Upload") ---
ASC_KEY_ID=YQHNLVGDWK
ASC_ISSUER_ID=f026f849-65f1-4ca4-9d49-1b6764131f40
ASC_PRIVATE_KEY_PATH=~/.appstoreconnect/private_keys/AuthKey_YQHNLVGDWK.p8

# --- App Store Connect web login (Playwright UI-only steps; 2FA still applies) ---
ASC_LOGIN_EMAIL="angchewhoe@gmail.com"
ASC_LOGIN_PASSWORD="MingXuan@2024"

# --- App identity (PER PROJECT — fill these) ---
ASC_BUNDLE_ID=<FILL_BUNDLE_ID>            # reverse-DNS, e.g. com.tertiaryinfotech.aiexams
ASC_APP_ID=<FILL_APP_ID>                  # numeric ASC App ID for this app

# --- Version metadata ---
ASC_COPYRIGHT="2026 Tertiary Infotech Academy Pte Ltd"   # format: YYYY Tertiary Infotech Academy Pte Ltd
ASC_PRIVACY_POLICY_URL="<FILL_PRIVACY_POLICY_URL>"
ASC_SUPPORT_URL="<FILL_SUPPORT_URL>"
ASC_MARKETING_URL="<FILL_MARKETING_URL>"

# --- App Review contact (org standard) ---
ASC_CONTACT_FIRST="Alfred"
ASC_CONTACT_LAST="Ang"
ASC_CONTACT_PHONE="+6596983731"
ASC_CONTACT_EMAIL="angch@tertiaryinfotech.com"
ASC_REVIEW_NOTES="Demo account: <FILL_REVIEW_ACCOUNT_EMAIL> / <FILL_REVIEW_ACCOUNT_PASSWORD>. <one-line what the app does + how to reach in-app account deletion>."
